for file in 0-iam_betty 1-who_am_i 2-groups 3-new_owner 4-empty 5-execute 6-multiple_permissions 7-everybody 8-James_Bond 9-John_Doe 10-mirror_permissions 11-directories_permissions 12-directory_permissions 13-change_group 14-change_owner_and_group 15-symbolic_link_permissions 16-if_only; do case "$file" in 0-iam_betty) printf "su betty\n" > "$file" ;; 1-who_am_i) printf "#!/bin/bash\nwhoami\n" > "$file" ;; 2-groups) printf "#!/bin/bash\ngroups\n" > "$file" ;; 3-new_owner) printf "#!/bin/bash\nchown betty hello\n" > "$file" ;; 4-empty) printf "#!/bin/bash\ntouch hello\n" > "$file" ;; 5-execute) printf "#!/bin/bash\nchmod u+x hello\n" > "$file" ;; 6-multiple_permissions) printf "#!/bin/bash\nchmod u+x,g+x,o+r hello\n" > "$file" ;; 7-everybody) printf "#!/bin/bash\nchmod a+x hello\n" > "$file" ;; 8-James_Bond) printf "#!/bin/bash\nchmod 007 hello\n" > "$file" ;; 9-John_Doe) printf "#!/bin/bash\nchmod 753 hello\n" > "$file" ;; 10-mirror_permissions) printf "#!/bin/bash\nchmod --reference=olleh hello\n" > "$file" ;; 11-directories_permissions) printf "#!/bin/bash\nchmod -R a+X *\n" > "$file" ;; 12-directory_permissions) printf "#!/bin/bash\nmkdir -m 751 my_dir\n" > "$file" ;; 13-change_group) printf "#!/bin/bash\nchgrp school hello\n" > "$file" ;; 14-change_owner_and_group) printf "#!/bin/bash\nchown -R vincent:staff *\n" > "$file" ;; 15-symbolic_link_permissions) printf "#!/bin/bash\nchown -h vincent:staff _hello\n" > "$file" ;; 16-if_only) printf "#!/bin/bash\nchown --from=guillaume vincent hello\n" > "$file" ;; esac; chmod u+x "$file"; done
